# VaultGuard Backend Environment Configuration
# Copy this file to .env and fill in your actual values
# WARNING: Never commit .env files with real credentials to version control

# Server Configuration
NODE_ENV=development
PORT=3001

# Supabase Configuration
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# JWT Configuration - SECURE SECRETS GENERATED FOR PRODUCTION
JWT_SECRET=your-super-secure-jwt-secret-here-min-32-chars

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password-here
REDIS_URL=redis://localhost:6379

# Stripe Keys (Optional - for fiat payments)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here

# BTCPay Server Configuration (Optional - for crypto payments)
# Get these values from your BTCPay Server instance at https://your-btcpay-server.com/stores/your-store-id/integrations
BTCPAY_SERVER_URL=https://your-btcpay-server.com
BTCPAY_API_KEY=your-btcpay-api-key-here
BTCPAY_WEBHOOK_SECRET=your-btcpay-webhook-secret-here
BTCPAY_STORE_ID=your-btcpay-store-id-here

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Email Configuration (Gmail SMTP)
# To use Gmail SMTP, you need to:
# 1. Enable 2-factor authentication on your Gmail account
# 2. Generate an App Password: https://myaccount.google.com/apppasswords
# 3. Use your Gmail address as EMAIL_USER (e.g., your-email@gmail.com)
# 4. Use the 16-character App Password as EMAIL_PASS (not your regular password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-16-character-app-password
EMAIL_SENDER=noreply@yourdomain.com

# Threat Intelligence API Keys
VIRUSTOTAL_API_KEY=your-virustotal-api-key
ABUSEIPDB_API_KEY=your-abuseipdb-api-key
SHODAN_API_KEY=your-shodan-api-key

# OSINT API Keys
OSINTCAT_API_KEY=your-osintcat-api-key
CSINT_CREDENTIALS=your-csint-credentials
RAPIDX_API_KEY=your-rapidapi-key
CENSYS_API_KEY=your-censys-api-key

# Neutrino API Keys
NEUTRINO_API_KEY_ROOT=your-neutrino-root-key
NEUTRINO_API_KEY_TESTING=your-neutrino-testing-key
NEUTRINO_API_KEY_PRODUCTION=your-neutrino-production-key

# OpenRouter AI API
OPENROUTER_API_KEY=your-openrouter-api-key

# MongoDB API
MONGODB_PUBLIC_KEY=your-mongodb-public-key
MONGODB_PRIVATE_KEY=your-mongodb-private-key

# Blockchain Intelligence APIs
CHAINALYSIS_API_URL=https://api.chainalysis.com
CHAINALYSIS_API_KEY=your-chainalysis-api-key
ELLIPTIC_API_URL=https://api.elliptic.co
ELLIPTIC_API_KEY=your-elliptic-api-key
CIPHERTRACE_API_URL=https://api.ciphertrace.com
CIPHERTRACE_API_KEY=your-ciphertrace-api-key

# Regulatory APIs
SEC_API_URL=https://api.sec.gov
SEC_API_KEY=your-sec-api-key
FCA_API_URL=https://api.fca.org.uk
FCA_API_KEY=your-fca-api-key
FINMA_API_URL=https://api.finma.ch
FINMA_API_KEY=your-finma-api-key

# LOG Configuration
LOG_LEVEL=info

# Cookie Secret
COOKIE_SECRET=your-cookie-secret-change-in-production

# Your Wallet Addresses for Crypto Payments
# IMPORTANT: Replace these with your actual wallet addresses in your .env file
# WARNING: Never commit your actual .env file with real addresses to version control
PAYMENT_WALLET_BTC=bc1qxy2kgdygjrsqtzq2n0yrf2493p83kkfjhx0wlh
PAYMENT_WALLET_ETH=0x742d35Cc6635C0532925a3b8D0C0C0B1c8B5d8E8
